<?xml version="1.0" encoding="UTF-8"?>
<!--
  Log4j2 configuration for LIMS
  - Console: JSON structured output (Google Cloud Logging compatible)
  - File: rolling JSON logs (kept locally / mounted volume)
  - Google Cloud Logging appender: activated when running on GCP (env GCP_PROJECT_ID set)
-->
<Configuration status="WARN" monitorInterval="30">

  <Properties>
    <Property name="APP_NAME">lims</Property>
    <Property name="LOG_DIR">${env:LOG_DIR:-logs}</Property>
    <Property name="LOG_LEVEL_ROOT">${env:LOG_LEVEL_ROOT:-INFO}</Property>
    <Property name="LOG_LEVEL_APP">${env:LOG_LEVEL_APP:-DEBUG}</Property>
  </Properties>

  <Appenders>

    <!-- Console: JSON layout (Google Cloud Logging parses structured JSON) -->
    <Console name="ConsoleJson" target="SYSTEM_OUT">
      <JsonTemplateLayout eventTemplateUri="classpath:log4j2/GcpLayout.json"/>
    </Console>

    <!-- File: rolling JSON log -->
    <RollingFile name="RollingFileJson"
                 fileName="${LOG_DIR}/${APP_NAME}.log"
                 filePattern="${LOG_DIR}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
      <JsonTemplateLayout eventTemplateUri="classpath:log4j2/GcpLayout.json"/>
      <Policies>
        <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
        <SizeBasedTriggeringPolicy size="50MB"/>
      </Policies>
      <DefaultRolloverStrategy max="30"/>
    </RollingFile>

    <!-- Async wrapper for non-blocking I/O -->
    <Async name="AsyncConsole">
      <AppenderRef ref="ConsoleJson"/>
    </Async>
    <Async name="AsyncFile">
      <AppenderRef ref="RollingFileJson"/>
    </Async>

  </Appenders>

  <Loggers>

    <!-- Application packages -->
    <Logger name="com.sivayahealth" level="${LOG_LEVEL_APP}" additivity="false">
      <AppenderRef ref="AsyncConsole"/>
      <AppenderRef ref="AsyncFile"/>
    </Logger>

    <!-- Spring Security - keep at INFO to avoid token noise -->
    <Logger name="org.springframework.security" level="INFO" additivity="false">
      <AppenderRef ref="AsyncConsole"/>
      <AppenderRef ref="AsyncFile"/>
    </Logger>

    <!-- Hibernate SQL - only enable in DEBUG mode -->
    <Logger name="org.hibernate.SQL" level="${env:HIBERNATE_SQL_LOG:-WARN}" additivity="false">
      <AppenderRef ref="AsyncConsole"/>
    </Logger>

    <!-- Flyway migrations -->
    <Logger name="org.flywaydb" level="INFO" additivity="false">
      <AppenderRef ref="AsyncConsole"/>
      <AppenderRef ref="AsyncFile"/>
    </Logger>

    <!-- Google Cloud client libraries -->
    <Logger name="com.google.cloud" level="WARN" additivity="false">
      <AppenderRef ref="AsyncConsole"/>
    </Logger>

    <!-- Micrometer -->
    <Logger name="io.micrometer" level="WARN" additivity="false">
      <AppenderRef ref="AsyncConsole"/>
    </Logger>

    <Root level="${LOG_LEVEL_ROOT}">
      <AppenderRef ref="AsyncConsole"/>
      <AppenderRef ref="AsyncFile"/>
    </Root>

  </Loggers>

</Configuration>
