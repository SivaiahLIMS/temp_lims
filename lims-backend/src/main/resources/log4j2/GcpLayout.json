{
  "severity": {
    "$resolver": "level",
    "field": "name"
  },
  "message": {
    "$resolver": "message",
    "stringified": true
  },
  "timestamp": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSSXXX",
      "timeZone": "UTC"
    }
  },
  "logger": {
    "$resolver": "logger",
    "field": "name"
  },
  "thread": {
    "$resolver": "thread",
    "field": "name"
  },
  "context": {
    "$resolver": "mdc",
    "flatten": {
      "prefix": "labels."
    }
  },
  "exception": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stackTrace": {
      "stringified": true
    }
  },
  "serviceContext": {
    "service": "${env:K_SERVICE:-lims}",
    "version": "${env:K_REVISION:-local}"
  },
  "httpRequest": {
    "$resolver": "mdc",
    "key": "httpRequest"
  },
  "traceId": {
    "$resolver": "mdc",
    "key": "traceId"
  },
  "spanId": {
    "$resolver": "mdc",
    "key": "spanId"
  },
  "tenantId": {
    "$resolver": "mdc",
    "key": "tenantId"
  },
  "userId": {
    "$resolver": "mdc",
    "key": "userId"
  }
}
